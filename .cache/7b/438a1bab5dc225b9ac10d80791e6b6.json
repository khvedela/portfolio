\n}\r\n\r\n.btn-linkedin {\r\n    background: rgba( 5, 129, 251, 0.25 );\r\n    box-shadow: 0 8px 32px 0 rgba( 31, 38, 135, 0.37 );\r\n    backdrop-filter: blur( 4px );\r\n    -webkit-backdrop-filter: blur( 4px );\r\n    border: 1px solid rgba( 255, 255, 255, 0.18 );\r\n\r\n}\r\n\r\n.btn-linkedin:hover {\r\n    background: rgba(4, 91, 179, 0.25);\r\n    box-shadow: 0 8px 32px 0 rgba(4, 91, 179, 0.25);\r\n    backdrop-filter: blur( 4px );\r\n    -webkit-backdrop-filter: blur( 4px );\r\n    border: 1px solid rgba(160, 159, 159, 0.18);\r\n}\r\n\r\n\r\n.btn-instagram {\r\n    background: rgba( 251, 21, 5, 0.25 );\r\n    box-shadow: 0 8px 32px 0 rgba( 31, 38, 135, 0.37 );\r\n    backdrop-filter: blur( 4px );\r\n    -webkit-backdrop-filter: blur( 4px );\r\n    border: 1px solid rgba( 255, 255, 255, 0.18 );\r\n}\r\n\r\n.btn-instagram:hover {\r\n    background: rgba(136, 17, 9, 0.25);\r\n    box-shadow: 0 8px 32px 0 rgba(20, 24, 87, 0.37);\r\n    backdrop-filter: blur( 4px );\r\n    -webkit-backdrop-filter: blur( 4px );\r\n    border: 1px solid rgba(160, 159, 159, 0.18);\r\n}\r\n\r\n.btn-github {\r\n    background: rgba( 60, 58, 58, 0.25 );\r\n    box-shadow: 0 8px 32px 0 rgba( 31, 38, 135, 0.37 );\r\n    backdrop-filter: blur( 4px );\r\n    -webkit-backdrop-filter: blur( 4px );\r\n    border: 1px solid rgba( 255, 255, 255, 0.18 );\r\n}\r\n\r\n.btn-github:hover {\r\n    background: rgba(39, 38, 38, 0.25);\r\n    box-shadow: 0 8px 32px 0 rgba(22, 27, 93, 0.37);\r\n    backdrop-filter: blur( 4px );\r\n    -webkit-backdrop-filter: blur( 4px );\r\n    border: 1px solid rgba(160, 159, 159, 0.18);\r\n}\r\n\r\n/* mobile */\r\n@media only screen and (max-width: 820px) {\r\n    .container h1 {\r\n        text-align: center;\r\n        font-size: 8vw;\r\n    }\r\n    \r\n    .container p {\r\n        font-size: 4vw;\r\n    }\r\n}"},"lineCount":null}},"error":null,"hash":"796b59344939c3a9e77f516f7a6b520d","cacheData":{"env":{}}}